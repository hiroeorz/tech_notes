{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [".agents/skills", ".opencode/skills"]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--caps",
        "vision"
      ],
      "enabled": true,
      "environment": {
        "PLAYWRIGHT_BROWSERS_PATH": "0"
      }
    }
  }
}
