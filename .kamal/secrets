# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Improve security by using a password manager. Never check config/master.key into git!
RAILS_MASTER_KEY=$(cat config/master.key)

# PostgreSQL password for the Kamal db accessory.
# Set POSTGRES_PASSWORD in your environment before running kamal.
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# Docker Hub access token. Set KAMAL_REGISTRY_PASSWORD in your environment before running kamal.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY_ID=$CLOUDFLARE_R2_ACCESS_KEY_ID
CLOUDFLARE_R2_SECRET_ACCESS_KEY=$CLOUDFLARE_R2_SECRET_ACCESS_KEY
CLOUDFLARE_R2_BUCKET=$CLOUDFLARE_R2_BUCKET
CLOUDFLARE_R2_ENDPOINT=$CLOUDFLARE_R2_ENDPOINT
ACTIVE_STORAGE_PUBLIC_BASE_URL=$ACTIVE_STORAGE_PUBLIC_BASE_URL

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=$CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_AI_API_TOKEN=$CLOUDFLARE_AI_API_TOKEN
CLOUDFLARE_AI_MODEL=$CLOUDFLARE_AI_MODEL
CLOUDFLARE_AI_TIMEOUT_SECONDS=$CLOUDFLARE_AI_TIMEOUT_SECONDS

# Google Search Console site verification token.
# Set GOOGLE_SITE_VERIFICATION in your environment before running kamal.
GOOGLE_SITE_VERIFICATION=$GOOGLE_SITE_VERIFICATION

# Cloudflare Turnstile (bot detection for comments).
# Set TURNSTILE_SITE_KEY and TURNSTILE_SECRET_KEY in your environment before running kamal.
TURNSTILE_SITE_KEY=$TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=$TURNSTILE_SECRET_KEY
