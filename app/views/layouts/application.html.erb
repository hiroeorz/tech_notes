<!DOCTYPE html>
<html class="<%= "theme-dark" if current_site_setting.default_theme == "dark" %>" data-default-theme="<%= current_site_setting.default_theme %>">
  <head>
    <title><%= @page_title || content_for(:title) || "Hiroe Tech Notes" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= @page_description || content_for(:description) || current_site_setting.description %>">
    <meta property="og:site_name" content="<%= current_site_setting.blog_title %>">
    <meta property="og:title" content="<%= @page_title || content_for(:title) || current_site_setting.blog_title %>">
    <meta property="og:description" content="<%= @page_description || content_for(:description) || current_site_setting.description %>">
    <meta property="og:type" content="<%= @page_type || "website" %>">
    <meta property="og:url" content="<%= @page_url || request.original_url %>">
    <link rel="canonical" href="<%= @page_url || request.original_url %>">
    <% if current_site_setting.ogp_image.attached? && current_site_setting.ogp_image.blob.persisted? %>
      <meta property="og:image" content="<%= url_for(current_site_setting.ogp_image) %>">
    <% end %>
    <%= tag.link rel: "alternate", type: "application/rss+xml", title: "#{current_site_setting.blog_title} RSS", href: feed_url(format: :xml) %>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hiroe Tech Notes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= controller_path.tr('/', '-') %> <%= action_name %>">
    <div class="notebook-page">
      <div class="rings" aria-hidden="true">
        <% 22.times do %>
          <span></span>
        <% end %>
      </div>

      <%= render "shared/header" %>

      <% if notice.present? || alert.present? %>
        <div class="flash-wrap">
          <p class="flash <%= alert.present? ? "alert" : "notice" %>"><%= alert || notice %></p>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
