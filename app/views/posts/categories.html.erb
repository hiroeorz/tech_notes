<main class="single-page">
  <nav class="breadcrumbs">
    <%= link_to "ホーム", root_path %>
    <span>›</span>
    <span>カテゴリ一覧</span>
  </nav>

  <h1>カテゴリ一覧</h1>

  <div class="tag-cloud category-cloud">
    <% @categories.each do |category| %>
      <%= link_to posts_path(category: category.slug), class: "tag-pill category-pill" do %>
        <span><%= category_icon(category.icon_key) %> <%= category.name %></span>
        <strong><%= category.respond_to?(:posts_count) ? category.posts_count : category.posts.count %></strong>
      <% end %>
    <% end %>
  </div>
</main>
