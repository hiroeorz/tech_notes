<% if turnstile_enabled? %>
  <% content_for :head do %>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <% end %>
<% end %>
<main class="page-grid show-page">
  <article class="content-area article-content">
    <nav class="breadcrumbs">
      <%= link_to t("posts.show.home"), root_path %>
      <span>›</span>
      <%= link_to t("posts.show.articles"), posts_path %>
      <span>›</span>
      <span><%= @post.category.localized_name %></span>
    </nav>

    <div class="article-label"><%= @post.category.localized_name %> / <%= @post.tags.first&.name || "Tech" %></div>
    <h1><%= @post.localized_title %></h1>
    <% if admin_signed_in? %>
      <div class="article-admin-actions">
        <%= link_to t("posts.show.edit"), edit_admin_post_path(@post.slug), class: "admin-edit-link" %>
      </div>
    <% end %>
    <div class="article-meta">
      <span>▦ <%= @post.display_date.strftime("%Y-%m-%d") %></span>
      <span>↻ <%= t("posts.show.updated") %> <%= @post.updated_at.strftime("%Y-%m-%d") %></span>
      <span>◷ <%= @post.reading_minutes %><%= t("posts.show.minutes") %></span>
      <span>♙ <%= current_site_setting.profile_name %></span>
      <% @post.tags.each do |tag| %>
        <%= link_to tag.name, posts_path(tag: tag.slug), class: "chip" %>
      <% end %>
    </div>

    <div class="article-actions">
      <%= link_to "https://x.com/intent/tweet?url=#{ERB::Util.url_encode(request.original_url)}&text=#{ERB::Util.url_encode(share_text_for_x(@post))}",
          class: "share-x-button",
          aria: { label: t("posts.show.aria_share_x_article") },
          target: "_blank",
          rel: "noopener noreferrer" do %>
        <span class="x-icon">𝕏</span>
        <span><%= t("posts.show.share_on_x") %></span>
      <% end %>
      <% audio = @post.audio_for_locale %>
      <% if audio&.file&.attached? %>
        <%= render "posts/audio_player", audio: audio %>
      <% end %>
    </div>

    <% if @toc.present? %>
      <div class="mobile-toc-box mobile-only" data-controller="toc-toggle">
        <div class="mobile-toc-header" role="button" tabindex="0" aria-expanded="false" data-action="click->toc-toggle#toggle keydown.enter->toc-toggle#toggle keydown.space->toc-toggle#toggle">
          <span>☰</span>
          <span><%= t("posts.show.mobile_toc") %></span>
          <span class="toc-toggle-icon">▾</span>
        </div>
        <div class="mobile-toc-body" hidden data-toc-toggle-target="body">
          <ol>
            <% @toc.each do |id, title| %>
              <li><a href="#<%= id %>"><%= title %></a></li>
            <% end %>
          </ol>
        </div>
      </div>
    <% end %>

    <div class="markdown-body" data-image-lightbox>
      <%= render_markdown(@post.localized_body) %>
    </div>

    <% if @related_posts.present? %>
      <div class="mobile-related-posts mobile-only">
        <h3><%= t("posts.show.related_posts") %></h3>
        <% @related_posts.each do |post| %>
          <%= link_to post_path(post), class: "mobile-related-item" do %>
            <span><%= post.localized_title %></span>
            <time><%= l(post.display_date, format: :short) %></time>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <div class="mobile-share mobile-only">
      <span><%= t("posts.show.share") %></span>
      <%= link_to "GitHub", current_site_setting.github_url, aria: { label: "GitHub" } if current_site_setting.github_url.present? %>
      <%= link_to "𝕏", "https://x.com/intent/tweet?url=#{ERB::Util.url_encode(request.original_url)}&text=#{ERB::Util.url_encode(@post.localized_title)}", aria: { label: t("posts.show.aria_share_x") } %>
      <%= link_to "RSS", feed_path(format: :xml), aria: { label: "RSS" } %>
    </div>

    <footer class="article-footer"><%= t("posts.show.copyright") %></footer>

    <%= render "posts/comments" %>
  </article>

  <%= render "shared/sidebar", toc: @toc, tags: @post.tags, related_posts: @related_posts, share: true %>
</main>
