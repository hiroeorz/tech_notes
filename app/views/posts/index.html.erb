<main class="page-grid list-public-page">
  <% list_path = ->(query = {}) { @kind == "experiment" ? experiments_path(query) : posts_path(query) } %>
  <% preserved_filter_params = request.query_parameters.slice("q", "tag", "month", "sort") %>
  <% search_params = request.query_parameters.slice("category", "tag", "month") %>

  <section class="content-area">
    <nav class="breadcrumbs">
      <%= link_to t("posts.index.home"), root_path %>
      <span>›</span>
      <span><%= @kind == "experiment" ? t("posts.index.title_experiments") : t("posts.index.title_articles") %></span>
    </nav>

    <div class="page-title-row">
      <h1><%= @kind == "experiment" ? t("posts.index.title_experiments") : t("posts.index.title_articles") %></h1>
      <%= form_with url: list_path.call, method: :get, class: "search-inline" do |form| %>
        <% search_params.each do |key, value| %>
          <%= hidden_field_tag key, value %>
        <% end %>
        <%= form.search_field :q, value: params[:q], placeholder: t("posts.index.search_placeholder"), aria: { label: t("posts.index.search_placeholder") } %>
        <%= form.select :sort, options_for_select([ [ t("posts.index.sort_newest"), "newest" ], [ t("posts.index.sort_oldest"), "oldest" ], [ t("posts.index.sort_updated"), "updated" ] ], params[:sort].presence || "newest"), {}, aria: { label: t("posts.index.sort_aria") }, onchange: "this.form.requestSubmit()" %>
        <%= form.submit t("posts.index.search_button") %>
        <%= link_to t("posts.index.reset"), list_path.call, class: "secondary-button" %>
      <% end %>
    </div>

    <div class="filter-tabs wide-tabs">
      <%= link_to t("posts.index.all"), list_path.call, class: ("active" if params[:category].blank?) %>
      <% @categories.each do |category| %>
        <%= link_to category.name, list_path.call(preserved_filter_params.merge(category: category.slug)), class: ("active" if params[:category] == category.slug) %>
      <% end %>
    </div>

    <div class="post-list-cards">
      <% @posts.each do |post| %>
        <article class="post-list-card">
          <div class="document-icon">▤</div>
          <div>
            <p class="post-meta"><%= post.display_date.strftime("%Y-%m-%d") %> / <%= post.category.name %> / <%= post.reading_minutes %><%= t("posts.index.minutes") %></p>
            <h2><%= link_to post.localized_title, post_path(post) %></h2>
            <p><%= post.localized_excerpt %></p>
            <div class="chip-list">
              <% post.tags.each do |tag| %>
                <%= link_to tag.name, posts_path(tag: tag.slug), class: "chip" %>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>

    <nav class="pagination">
      <% if @page > 1 %>
        <%= link_to t("posts.index.prev"), list_path.call(request.query_parameters.merge(page: @page - 1)) %>
      <% else %>
        <span><%= t("posts.index.prev") %></span>
      <% end %>
      <% 1.upto(@total_pages) do |page| %>
        <% if page == @page %>
          <strong><%= page %></strong>
        <% else %>
          <%= link_to page, list_path.call(request.query_parameters.merge(page: page)) %>
        <% end %>
      <% end %>
      <% if @page < @total_pages %>
        <%= link_to t("posts.index.next"), list_path.call(request.query_parameters.merge(page: @page + 1)) %>
      <% else %>
        <span><%= t("posts.index.next") %></span>
      <% end %>
    </nav>
    <p class="page-count"><%= t("posts.index.page_info", page: @page, total_pages: @total_pages, count: @total_count) %></p>
  </section>

  <%= render "shared/sidebar", categories: @categories, archives: @archives %>
</main>
