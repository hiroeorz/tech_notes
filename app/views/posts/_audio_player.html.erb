<div data-controller="audio-player"
     data-open-value="false"
     data-playing-value="false"
     data-open-label="<%= t("posts.show.listen_to_article") %>"
     data-close-label="<%= t("posts.show.close_player") %>"
     data-play-label="<%= t("posts.show.play") %>"
     data-pause-label="<%= t("posts.show.pause") %>"
     data-error-message="<%= t("posts.show.audio_error") %>"
     class="audio-player-wrapper">
  <button type="button"
          data-action="audio-player#togglePanel"
          data-audio-player-target="button"
          class="audio-player-toggle-button">
    <span class="audio-player-toggle-icon"><%= "\u266C" %></span>
    <span data-audio-player-target="buttonLabel"><%= t("posts.show.listen_to_article") %></span>
  </button>

  <div class="audio-player-panel"
       data-audio-player-target="panel"
       hidden>
    <div class="audio-player-panel-header">
      <div class="audio-player-onair">
        <span class="audio-player-onair-dot" data-audio-player-target="onairDot"></span>
        <span>ON AIR</span>
      </div>
      <button type="button"
              data-action="audio-player#togglePanel"
              class="audio-player-close"
               aria-label="<%= t("posts.show.close_player") %>"><%= "\u2715" %></button>
    </div>

    <div class="audio-player-dial-area">
      <button type="button"
              data-action="audio-player#togglePlay"
              data-audio-player-target="playButton"
              class="audio-player-dial"
              aria-label="<%= t("posts.show.play") %>">
        <span data-audio-player-target="playIcon"><%= "\u25B6" %></span>
      </button>
    </div>

    <div class="audio-player-progress-area">
      <input type="range"
             data-action="input->audio-player#seek"
             data-audio-player-target="progress"
             class="audio-player-progress"
             min="0"
             max="100"
             value="0"
             step="0.1"
             aria-label="<%= t("posts.show.seek") %>">
      <div class="audio-player-times">
        <span data-audio-player-target="currentTime">0:00</span>
        <span data-audio-player-target="duration">--:--</span>
      </div>
    </div>

    <div class="audio-player-radio-label">RADIO</div>

    <div class="audio-player-error" data-audio-player-target="errorMessage" hidden></div>
  </div>

  <audio preload="metadata"
         data-audio-player-target="audio"
         data-action="timeupdate->audio-player#updateProgress loadedmetadata->audio-player#onMetadataLoaded ended->audio-player#onEnded error->audio-player#onError">
    <source src="<%= url_for(audio.file) %>" type="audio/mpeg">
    <%= t("posts.show.audio_unsupported") %>
  </audio>
</div>
