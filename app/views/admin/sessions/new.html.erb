<main class="login-page-main">
  <div class="login-illustration" aria-hidden="true">
    <span class="terminal-doodle">&gt;_</span>
    <span class="notebook-doodle"></span>
    <span class="pencil-doodle"></span>
    <span class="leaf-doodle">⌇</span>
  </div>

  <section class="login-card">
    <h1>ログイン</h1>
    <p>記事の作成・編集を行うためにサインインしてください。</p>

    <% if @login_errors.present? %>
      <div class="error-box">
        <% @login_errors.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with url: admin_login_path, class: "login-form" do |form| %>
      <label>
        <span>メールアドレス</span>
        <%= form.email_field :email, placeholder: "例）hiroe@example.com", required: true %>
      </label>
      <label>
        <span>パスワード</span>
        <div class="password-field">
          <%= form.password_field :password, placeholder: "パスワードを入力", required: true %>
          <button type="button" data-password-toggle aria-label="パスワードの表示切り替え">◎</button>
        </div>
      </label>
      <div class="login-options">
        <label><%= form.check_box :remember_me %> ログイン状態を保持する</label>
        <a href="#">パスワードを忘れた場合</a>
      </div>
      <%= form.submit "ログイン", class: "primary-button wide" %>
    <% end %>
  </section>

  <p class="admin-note">▣ 管理者専用ページです</p>
</main>
