<% if turnstile_enabled? %>
  <% content_for :head do %>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <% end %>
<% end %>
<main class="login-page-main">
  <div class="login-illustration" aria-hidden="true">
    <span class="terminal-doodle">&gt;_</span>
    <span class="notebook-doodle"></span>
    <span class="pencil-doodle"></span>
    <span class="leaf-doodle">⌇</span>
  </div>

  <section class="login-card">
    <h1><%= t("admin.sessions.new.title") %></h1>
    <p><%= t("admin.sessions.new.description") %></p>

    <% if @login_errors.present? %>
      <div class="error-box">
        <% @login_errors.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <% html_opts = { class: "login-form" } %>
    <% html_opts["data-controller"] = "login-form" if turnstile_enabled? %>
    <% html_opts["data-login-form-site-key-value"] = turnstile_site_key if turnstile_enabled? %>
    <%= form_with url: admin_login_path, html: html_opts do |form| %>
      <label>
        <span><%= t("admin.sessions.new.email_label") %></span>
        <%= form.email_field :email, placeholder: t("admin.sessions.new.email_placeholder"), required: true %>
      </label>
      <label>
        <span><%= t("admin.sessions.new.password_label") %></span>
        <div class="password-field">
          <%= form.password_field :password, placeholder: t("admin.sessions.new.password_placeholder"), required: true %>
          <%= button_tag type: "button", data: { password_toggle: true, password_toggle_label: t("admin.sessions.new.password_label"), password_toggle_show: t("js.password_toggle.show"), password_toggle_hide: t("js.password_toggle.hide") }, aria: { label: t("js.password_toggle.show"), pressed: "false" } do %>
            ◎
          <% end %>
        </div>
      </label>
      <div class="login-options">
        <label><%= form.check_box :remember_me %> <%= t("admin.sessions.new.remember_me") %></label>
        <%= mail_to current_site_setting.profile_email, t("admin.sessions.new.forgot_password"), subject: "Hiroe Tech Notes パスワード再設定依頼" %>
      </div>
      <% if turnstile_enabled? %>
        <div class="turnstile-wrap" data-login-form-target="turnstile"></div>
      <% end %>

      <%= form.submit t("admin.sessions.new.submit"), class: "primary-button wide", data: (turnstile_enabled? ? { "login-form-target" => "submit" } : {}) %>
    <% end %>
  </section>

  <p class="admin-note"><%= t("admin.sessions.new.admin_note") %></p>
</main>
