<% if turnstile_enabled? %>
  <% content_for :head do %>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <% end %>
<% end %>
<main class="login-page-main">
  <div class="login-illustration" aria-hidden="true">
    <span class="terminal-doodle">&gt;_</span>
    <span class="notebook-doodle"></span>
    <span class="pencil-doodle"></span>
    <span class="leaf-doodle">⌇</span>
  </div>

  <section class="login-card">
    <h1>ログイン</h1>
    <p>記事の作成・編集を行うためにサインインしてください。</p>

    <% if @login_errors.present? %>
      <div class="error-box">
        <% @login_errors.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <% html_opts = { class: "login-form" } %>
    <% html_opts["data-controller"] = "login-form" if turnstile_enabled? %>
    <% html_opts["data-login-form-site-key-value"] = turnstile_site_key if turnstile_enabled? %>
    <%= form_with url: admin_login_path, html: html_opts do |form| %>
      <label>
        <span>メールアドレス</span>
        <%= form.email_field :email, placeholder: "例）hiroe@example.com", required: true %>
      </label>
      <label>
        <span>パスワード</span>
        <div class="password-field">
          <%= form.password_field :password, placeholder: "パスワードを入力", required: true %>
          <button type="button" data-password-toggle data-password-toggle-label="パスワード" aria-label="パスワードを表示する" aria-pressed="false">◎</button>
        </div>
      </label>
      <div class="login-options">
        <label><%= form.check_box :remember_me %> ログイン状態を保持する</label>
        <%= mail_to current_site_setting.profile_email, "パスワードを忘れた場合", subject: "Hiroe Tech Notes パスワード再設定依頼" %>
      </div>
      <% if turnstile_enabled? %>
        <div class="turnstile-wrap" data-login-form-target="turnstile"></div>
      <% end %>

      <%= form.submit "ログイン", class: "primary-button wide", data: (turnstile_enabled? ? { "login-form-target" => "submit" } : {}) %>
    <% end %>
  </section>

  <p class="admin-note">▣ 管理者専用ページです</p>
</main>
