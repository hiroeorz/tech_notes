<main class="admin-page">
  <nav class="breadcrumbs">
    <%= link_to t("admin.comments.index.home"), root_path %>
    <span>›</span>
    <span><%= t("admin.comments.index.admin") %></span>
    <span>›</span>
    <span><%= t("admin.comments.index.title") %></span>
  </nav>

  <div class="admin-title-row">
    <h1><%= t("admin.comments.index.title") %></h1>
    <div class="title-actions">
      <%= link_to t("admin.comments.index.posts_link"), admin_posts_path, class: "secondary-button" %>
    </div>
  </div>

  <section class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th><%= t("admin.comments.index.header_author") %></th>
          <th><%= t("admin.comments.index.header_body") %></th>
          <th><%= t("admin.comments.index.header_post") %></th>
          <th><%= t("admin.comments.index.header_date") %></th>
          <th><%= t("admin.comments.index.header_actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% if @comments.empty? %>
          <tr>
            <td colspan="5" style="text-align:center;padding:32px;color:var(--muted);"><%= t("admin.comments.index.empty") %></td>
          </tr>
        <% else %>
          <% @comments.each do |comment| %>
            <tr>
              <td><strong><%= comment.author_name %></strong></td>
              <td style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                <%= truncate(strip_tags(comment.body), length: 80) %>
              </td>
              <td>
                <%= link_to comment.post.title, post_path(comment.post.slug), target: "_blank", class: "text-link" %>
              </td>
              <td><%= comment.created_at.strftime("%Y/%m/%d %H:%M") %></td>
              <td class="action-cell">
                <%= button_to t("admin.comments.index.delete"), admin_comment_path(comment), method: :delete, form: { data: { turbo_confirm: t("admin.comments.index.delete_confirm") } }, class: "danger-button" %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </section>
</main>
