<main class="admin-page">
  <nav class="breadcrumbs">
    <%= link_to t("admin.posts.index.home"), root_path %>
    <span>›</span>
    <span><%= t("admin.posts.index.admin") %></span>
    <span>›</span>
    <span><%= t("admin.posts.index.title") %></span>
  </nav>

  <div class="admin-title-row">
    <h1><%= t("admin.posts.index.title") %></h1>
    <div class="title-actions">
      <%= link_to t("admin.posts.index.settings"), admin_settings_path, class: "secondary-button" %>
      <span class="button-with-badge">
        <%= link_to t("admin.posts.index.comments"), admin_comments_path, class: "secondary-button" %>
        <% if @has_unread_comments %>
          <span class="badge-dot" aria="<%= { label: t("admin.posts.index.has_unread_aria") } %>"></span>
        <% end %>
      </span>
      <%= link_to t("admin.posts.index.new_post"), new_admin_post_path, class: "primary-button" %>
    </div>
  </div>

  <section class="stat-grid">
    <div class="stat-card"><span class="stat-icon">▤</span><strong><%= t("admin.posts.index.stat_total") %><%= @total_count %><%= t("admin.posts.index.count_suffix") %></strong><small><%= t("admin.posts.index.stat_all") %></small></div>
    <div class="stat-card"><span class="status-dot published"></span><strong><%= t("admin.posts.index.stat_published") %></strong><small><%= @published_count %><%= t("admin.posts.index.count_suffix") %></small></div>
    <div class="stat-card"><span class="status-dot draft"></span><strong><%= t("admin.posts.index.stat_draft") %></strong><small><%= @draft_count %><%= t("admin.posts.index.count_suffix") %></small></div>
    <div class="stat-card"><span class="status-dot reviewing"></span><strong><%= t("admin.posts.index.stat_reviewing") %></strong><small><%= @reviewing_count %><%= t("admin.posts.index.count_suffix") %></small></div>
  </section>

  <%= form_with url: admin_posts_path, method: :get, class: "filter-bar" do |form| %>
    <%= form.search_field :q, value: params[:q], placeholder: t("admin.posts.index.search_placeholder"), aria: { label: t("admin.posts.index.search_placeholder") } %>
    <%= form.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]), { include_blank: t("admin.posts.index.category_placeholder") }, aria: { label: "Filter by category" } %>
    <%= form.select :status, options_for_select(Post.statuses.keys.map { |status| [ status_label(status), status ] }, params[:status]), { include_blank: t("admin.posts.index.status_placeholder") }, aria: { label: "Filter by status" } %>
    <%= form.select :sort, options_for_select([ [ t("admin.posts.index.sort_newest"), "newest" ], [ t("admin.posts.index.sort_oldest"), "oldest" ] ], params[:sort]), {}, aria: { label: t("admin.posts.index.sort_aria") } %>
    <%= form.submit t("admin.posts.index.filter") %>
    <%= link_to t("admin.posts.index.reset"), admin_posts_path, class: "secondary-button" %>
  <% end %>

  <section class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th><%= t("admin.posts.index.header_title") %></th>
          <th><%= t("admin.posts.index.header_category") %></th>
          <th><%= t("admin.posts.index.header_status") %></th>
          <th><%= t("admin.posts.index.header_updated") %></th>
          <th><%= t("admin.posts.index.header_actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @posts.each do |post| %>
          <tr>
            <td class="title-cell">
              <span class="document-icon">▤</span>
              <div>
                <strong><%= post.title %></strong>
                <small><%= truncate(post.excerpt, length: 70) %></small>
              </div>
            </td>
            <td>
              <div class="chip-list">
                <span class="chip"><%= post.category.name %></span>
                <% post.tags.limit(3).each do |tag| %>
                  <span class="chip"><%= tag.name %></span>
                <% end %>
              </div>
            </td>
            <td><span class="status-badge <%= post.status %>">● <%= status_label(post.status) %></span></td>
            <td><%= post.updated_at.strftime("%Y/%m/%d %H:%M") %></td>
            <td class="action-cell">
              <%= link_to t("admin.posts.index.preview"), preview_admin_post_path(post.slug), class: "small-button" %>
              <%= link_to t("admin.posts.index.edit"), edit_admin_post_path(post.slug), class: "small-button" %>
              <%= button_to t("admin.posts.index.delete"), admin_post_path(post.slug), method: :delete, form: { data: { turbo_confirm: t("admin.posts.index.delete_confirm") } }, class: "danger-button" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>

  <nav class="pagination">
    <% if @page > 1 %>
      <%= link_to t("admin.posts.index.prev"), admin_posts_path(request.query_parameters.merge(page: @page - 1)) %>
    <% else %>
      <span><%= t("admin.posts.index.prev") %></span>
    <% end %>
    <% 1.upto(@total_pages) do |page| %>
      <% if page == @page %>
        <strong><%= page %></strong>
      <% else %>
        <%= link_to page, admin_posts_path(request.query_parameters.merge(page: page)) %>
      <% end %>
    <% end %>
    <% if @page < @total_pages %>
      <%= link_to t("admin.posts.index.next"), admin_posts_path(request.query_parameters.merge(page: @page + 1)) %>
    <% else %>
      <span><%= t("admin.posts.index.next") %></span>
    <% end %>
  </nav>
  <p class="page-count"><%= t("admin.posts.index.page_info", page: @page, total_pages: @total_pages, count: @filtered_count) %></p>
</main>
