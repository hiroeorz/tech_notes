<main class="editor-page">
  <nav class="breadcrumbs">
    <%= link_to t("admin.posts.form.home"), root_path %>
    <span>›</span>
    <%= link_to t("admin.posts.form.posts"), admin_posts_path %>
    <span>›</span>
    <span><%= post.persisted? ? t("admin.posts.form.edit") : t("admin.posts.form.new") %></span>
  </nav>

  <%= form_with model: [ :admin, post ], class: "editor-form", data: { controller: "post-summary", post_summary_url_value: admin_post_summaries_path, post_summary_slug_url_value: admin_post_slugs_path, post_summary_confirm_overwrite_excerpt_value: t("js.post_summary.confirm_overwrite_excerpt"), post_summary_generating_excerpt_value: t("js.post_summary.generating_excerpt"), post_summary_excerpt_success_value: t("js.post_summary.excerpt_success"), post_summary_excerpt_error_value: t("js.post_summary.excerpt_error"), post_summary_confirm_overwrite_slug_value: t("js.post_summary.confirm_overwrite_slug"), post_summary_generating_slug_value: t("js.post_summary.generating_slug"), post_summary_slug_success_value: t("js.post_summary.slug_success"), post_summary_slug_error_value: t("js.post_summary.slug_error"), post_summary_error_json_value: t("js.post_summary.error_json"), post_summary_error_401_value: t("js.post_summary.error_401"), post_summary_error_html_value: t("js.post_summary.error_html") } do |form| %>
    <% if post.errors.any? %>
      <div class="error-box"><%= post.errors.full_messages.join(" / ") %></div>
    <% end %>

    <div class="editor-title-row">
      <label class="editor-title-field">
        <span><%= t("admin.posts.form.title_label").html_safe %></span>
        <%= form.text_field :title, value: @form_content.fetch(:title), maxlength: 100, required: true, data: { live_count_input: "title", live_count_max: 100, post_summary_target: "title" } %>
        <em data-live-count-output="title"><%= @form_content.fetch(:title).to_s.length %> / 100</em>
      </label>

      <div class="editor-actions">
        <% if post.persisted? %>
          <span class="editor-views-count">◉ <%= post.views_count %> <%= t("admin.posts.form.views_label") %></span>
        <% end %>
        <button type="submit" name="commit_status" value="draft" class="secondary-button" formnovalidate><%= t("admin.posts.form.draft_save") %></button>
        <% if post.persisted? %>
          <%= link_to t("admin.posts.form.preview"), preview_admin_post_path(post.slug), class: "secondary-button" %>
        <% else %>
          <button type="button" class="secondary-button" data-open-editor-preview><%= t("admin.posts.form.preview") %></button>
        <% end %>
        <button type="button" class="primary-button" data-open-publish-modal><%= t("admin.posts.form.publish") %></button>
      </div>
    </div>

    <section class="markdown-editor" data-markdown-preview-url="<%= markdown_preview_admin_posts_path %>">
      <div class="editor-tabs">
        <button type="button" class="active" data-editor-tab="markdown"><%= t("admin.posts.form.tab_markdown") %></button>
        <button type="button" data-editor-tab="preview"><%= t("admin.posts.form.tab_preview") %></button>
        <a href="https://www.markdownguide.org/basic-syntax/" target="_blank" rel="noreferrer"><%= t("admin.posts.form.markdown_guide") %></a>
      </div>
      <%= tag.div class: "toolbar", aria: { label: t("admin.posts.form.toolbar_aria") } do %>
        <%= button_tag type: "button", data: { md_action: "bold" }, aria: { label: t("admin.posts.form.bold_aria") } do %><b>B</b><% end %>
        <%= button_tag type: "button", data: { md_action: "italic" }, aria: { label: t("admin.posts.form.italic_aria") } do %><i>I</i><% end %>
        <%= button_tag type: "button", data: { md_action: "code" }, aria: { label: t("admin.posts.form.code_aria") } do %>&lt;/&gt;<% end %>
        <%= button_tag type: "button", data: { md_action: "list" }, aria: { label: t("admin.posts.form.list_aria") } do %>☷<% end %>
        <%= button_tag type: "button", data: { md_action: "quote" }, aria: { label: t("admin.posts.form.quote_aria") } do %>❞<% end %>
        <%= button_tag type: "button", data: { md_action: "ordered" }, aria: { label: t("admin.posts.form.ordered_aria") } do %>1.<% end %>
        <%= button_tag type: "button", data: { md_action: "check" }, aria: { label: t("admin.posts.form.check_aria") } do %>☑<% end %>
        <%= button_tag type: "button", data: { md_action: "image" }, aria: { label: t("admin.posts.form.image_aria") } do %>▧<% end %>
        <%= button_tag type: "button", data: { md_action: "table" }, aria: { label: t("admin.posts.form.table_aria") } do %>▦<% end %>
        <%= button_tag type: "button", data: { md_action: "link" }, aria: { label: t("admin.posts.form.link_aria") } do %>↗<% end %>
      <% end %>
      <div class="post-image-uploader" data-post-image-panel>
        <% if post.persisted? %>
          <label>
            <span><%= t("admin.posts.form.image_section") %></span>
            <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" data-post-image-input data-upload-url="<%= admin_post_images_path(post) %>">
          </label>
          <p data-post-image-message><%= t("admin.posts.form.image_help") %></p>
        <% else %>
          <p><%= t("admin.posts.form.image_help_draft") %></p>
        <% end %>
      </div>
      <div class="textarea-shell">
        <div class="line-numbers"><% 44.times do |i| %><span><%= i + 1 %></span><% end %></div>
        <%= form.text_area :body, value: @form_content.fetch(:body), rows: 28, spellcheck: false, data: { markdown_source: true, body_stats_source: true, post_summary_target: "body" } %>
        <div class="markdown-preview" data-markdown-preview hidden></div>
      </div>
      <footer class="editor-footer">
        <span data-body-stat="lines"><%= t("admin.posts.form.lines_label") %> <%= @form_content.fetch(:body).to_s.lines.count %></span>
        <span data-body-stat="words"><%= t("admin.posts.form.words_label") %> <%= @form_content.fetch(:body).to_s.split.size %></span>
        <span data-body-stat="chars"><%= t("admin.posts.form.chars_label") %> <%= @form_content.fetch(:body).to_s.length %></span>
        <a href="https://www.markdownguide.org/basic-syntax/" target="_blank" rel="noreferrer"><%= t("admin.posts.form.markdown_guide_footer") %></a>
      </footer>
    </section>

    <% if post.persisted? %>
      <section class="post-image-list" aria-labelledby="post-images-title">
        <div class="post-image-list-header">
          <h2 id="post-images-title"><%= t("admin.posts.form.attached_images") %></h2>
          <p><%= t("admin.posts.form.attached_images_help") %></p>
        </div>
        <% if post.images.attached? %>
          <div class="post-image-grid">
            <% post.images.each do |image| %>
              <% public_url = post_image_public_url(image) %>
              <% markdown = post_image_markdown(image) %>
              <article class="post-image-item">
                <%= image_tag(public_url || image, alt: image.filename.to_s, class: "post-image-thumb") %>
                <div>
                  <strong><%= image.filename %></strong>
                  <small><%= human_image_size(image) %></small>
                  <% if public_url.present? %>
                    <code><%= public_url %></code>
                  <% else %>
                    <em><%= t("admin.posts.form.cdn_unconfigured") %></em>
                  <% end %>
                </div>
                <div class="post-image-actions">
                  <button type="button" class="secondary-button" data-insert-markdown="<%= markdown %>" <%= "disabled" if markdown.blank? %>><%= t("admin.posts.form.insert") %></button>
                  <%= link_to t("admin.posts.form.delete"), admin_post_image_path(post, image), class: "outline-danger", data: { turbo_method: :delete, turbo_confirm: t("admin.posts.form.delete_image_confirm") } %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="empty-note"><%= t("admin.posts.form.no_images") %></p>
        <% end %>
      </section>
    <% end %>

    <div class="modal-backdrop" data-publish-modal-backdrop hidden>
      <div class="publish-modal-card" role="dialog" aria-labelledby="modal-title" aria-modal="true">
        <div class="modal-header">
          <h2 id="modal-title"><%= t("admin.posts.form.modal_title") %></h2>
          <%= button_tag type: "button", class: "close-button", data: { close_publish_modal: true }, aria: { label: t("admin.posts.form.close_aria") } do %>✕<% end %>
        </div>
        <div class="modal-body">
          <div class="publish-modal-grid">
            <div class="publish-modal-left">
              <div class="publish-field">
                <span class="field-label-row">
                  <%= form.label :slug, t("admin.posts.form.slug_label").html_safe %>
                  <%= button_tag type: "button", class: "ai-icon-button", data: { action: "post-summary#generateSlug", post_summary_target: "slugButton", tooltip: t("admin.posts.form.slug_ai_tooltip") }, aria: { label: t("admin.posts.form.slug_ai_aria") } do %>🧠<% end %>
                </span>
                <%= form.text_field :slug, required: true, pattern: "[a-z0-9]+(-[a-z0-9]+)*", title: t("admin.posts.form.slug_pattern_title"), data: { post_summary_target: "slug" } %>
                <strong class="ai-summary-message" data-post-summary-target="slugMessage" hidden></strong>
              </div>

              <label class="publish-field">
                <span class="field-label-row"><%= t("admin.posts.form.tags_label") %></span>
                <%= form.text_field :tag_names, value: post.tag_names, placeholder: t("admin.posts.form.tags_placeholder"), data: { tag_input: true } %>
                <span class="tag-preview chip-list" data-tag-preview>
                  <% post.tag_names.split(",").map(&:strip).reject(&:blank?).each do |tag_name| %>
                    <span class="chip"><%= tag_name %></span>
                  <% end %>
                </span>
              </label>

              <div class="publish-field">
                <span class="field-label-row">
                  <%= form.label :excerpt, t("admin.posts.form.excerpt_label") %>
                  <%= button_tag type: "button", class: "ai-icon-button", data: { action: "post-summary#generate", post_summary_target: "button", tooltip: t("admin.posts.form.excerpt_ai_tooltip") }, aria: { label: t("admin.posts.form.excerpt_ai_aria") } do %>🧠<% end %>
                </span>
                <%= form.text_area :excerpt, value: @form_content.fetch(:excerpt), rows: 3, maxlength: 100, data: { live_count_input: "excerpt", live_count_max: 100, post_summary_target: "excerpt" } %>
                <em data-live-count-output="excerpt"><%= @form_content.fetch(:excerpt).to_s.length %> / 100</em>
                <strong class="ai-summary-message" data-post-summary-target="message" hidden></strong>
              </div>
            </div>

            <div class="publish-modal-right">
              <label class="publish-field">
                <span class="field-label-row"><%= t("admin.posts.form.category_label") %></span>
                <%= form.collection_select :category_id, categories, :id, :localized_name %>
              </label>

              <label class="publish-field">
                <span class="field-label-row"><%= t("admin.posts.form.status_label") %></span>
                <%= form.select :status, options_for_select(Post.statuses.keys.map { |status| [ status_label(status), status ] }, post.status) %>
              </label>

              <label class="publish-field">
                <span class="field-label-row"><%= t("admin.posts.form.published_at_label") %></span>
                <%= form.datetime_local_field :published_at %>
              </label>

              <label class="checkbox-label publish-checkbox">
                <%= form.check_box :generate_audio, checked: post.generate_audio? %>
                <span><%= t("admin.posts.form.generate_audio") %></span>
              </label>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="secondary-button" data-close-publish-modal><%= t("admin.posts.form.cancel") %></button>
          <button type="button" class="secondary-button" disabled><%= t("admin.posts.form.schedule") %></button>
          <button type="submit" name="commit_status" value="draft" class="secondary-button" formnovalidate><%= t("admin.posts.form.draft_save_modal") %></button>
          <button type="submit" name="commit_status" value="published" class="primary-button"><%= t("admin.posts.form.publish_submit") %></button>
        </div>
      </div>
    </div>
  <% end %>
</main>
