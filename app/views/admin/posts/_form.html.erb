<main class="editor-page">
  <nav class="breadcrumbs">
    <%= link_to "ホーム", root_path %>
    <span>›</span>
    <%= link_to "記事", admin_posts_path %>
    <span>›</span>
    <span><%= post.persisted? ? "編集" : "新規作成" %></span>
  </nav>

  <%= form_with model: [ :admin, post ], class: "editor-form", data: { controller: "post-summary", post_summary_url_value: admin_post_summaries_path } do |form| %>
    <% if post.errors.any? %>
      <div class="error-box"><%= post.errors.full_messages.join(" / ") %></div>
    <% end %>

    <div class="editor-title-row">
      <label class="editor-title-field">
        <span>タイトル <b>*</b></span>
        <%= form.text_field :title, maxlength: 100, required: true, data: { live_count_input: "title", live_count_max: 100, post_summary_target: "title" } %>
        <em data-live-count-output="title"><%= post.title.to_s.length %> / 100</em>
      </label>

      <div class="editor-actions">
        <button type="submit" name="commit_status" value="draft" class="secondary-button" formnovalidate>下書き保存</button>
        <% if post.persisted? %>
          <%= link_to "プレビュー", preview_admin_post_path(post.slug), class: "secondary-button" %>
        <% else %>
          <button type="button" class="secondary-button" data-open-editor-preview>プレビュー</button>
        <% end %>
        <button type="button" class="primary-button" data-open-publish-modal>公開 ▾</button>
      </div>
    </div>

    <section class="markdown-editor" data-markdown-preview-url="<%= markdown_preview_admin_posts_path %>">
      <div class="editor-tabs">
        <button type="button" class="active" data-editor-tab="markdown">Markdown</button>
        <button type="button" data-editor-tab="preview">プレビュー</button>
        <a href="https://www.markdownguide.org/basic-syntax/" target="_blank" rel="noreferrer">Markdownガイド ↗</a>
      </div>
      <div class="toolbar" aria-label="Markdownツールバー">
        <button type="button" data-md-action="bold" aria-label="太字を挿入"><b>B</b></button>
        <button type="button" data-md-action="italic" aria-label="斜体を挿入"><i>I</i></button>
        <button type="button" data-md-action="code" aria-label="コードを挿入">&lt;/&gt;</button>
        <button type="button" data-md-action="list" aria-label="箇条書きを挿入">☷</button>
        <button type="button" data-md-action="quote" aria-label="引用を挿入">❞</button>
        <button type="button" data-md-action="ordered" aria-label="番号付きリストを挿入">1.</button>
        <button type="button" data-md-action="check" aria-label="チェックボックスを挿入">☑</button>
        <button type="button" data-md-action="image" aria-label="画像を挿入">▧</button>
        <button type="button" data-md-action="table" aria-label="テーブルを挿入">▦</button>
        <button type="button" data-md-action="link" aria-label="リンクを挿入">↗</button>
      </div>
      <div class="post-image-uploader" data-post-image-panel>
        <% if post.persisted? %>
          <label>
            <span>記事画像</span>
            <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" data-post-image-input data-upload-url="<%= admin_post_images_path(post) %>">
          </label>
          <p data-post-image-message>画像を選択するとアップロードし、カーソル位置に Markdown を挿入します。</p>
        <% else %>
          <p>画像を追加するには、先に下書き保存してください。</p>
        <% end %>
      </div>
      <div class="textarea-shell">
        <div class="line-numbers"><% 44.times do |i| %><span><%= i + 1 %></span><% end %></div>
        <%= form.text_area :body, rows: 28, spellcheck: false, data: { markdown_source: true, body_stats_source: true, post_summary_target: "body" } %>
        <div class="markdown-preview" data-markdown-preview hidden></div>
      </div>
      <footer class="editor-footer">
        <span data-body-stat="lines">Lines: <%= post.body.to_s.lines.count %></span>
        <span data-body-stat="words">Words: <%= post.body.to_s.split.size %></span>
        <span data-body-stat="chars">文字数: <%= post.body.to_s.length %></span>
        <a href="https://www.markdownguide.org/basic-syntax/" target="_blank" rel="noreferrer">Markdown Guide ↗</a>
      </footer>
    </section>

    <% if post.persisted? %>
      <section class="post-image-list" aria-labelledby="post-images-title">
        <div class="post-image-list-header">
          <h2 id="post-images-title">添付画像</h2>
          <p>本文から Markdown を削除しても画像は残ります。不要な画像はここから削除してください。</p>
        </div>
        <% if post.images.attached? %>
          <div class="post-image-grid">
            <% post.images.each do |image| %>
              <% public_url = post_image_public_url(image) %>
              <% markdown = post_image_markdown(image) %>
              <article class="post-image-item">
                <%= image_tag(public_url || image, alt: image.filename.to_s, class: "post-image-thumb") %>
                <div>
                  <strong><%= image.filename %></strong>
                  <small><%= human_image_size(image) %></small>
                  <% if public_url.present? %>
                    <code><%= public_url %></code>
                  <% else %>
                    <em>CDN URL未設定</em>
                  <% end %>
                </div>
                <div class="post-image-actions">
                  <button type="button" class="secondary-button" data-insert-markdown="<%= markdown %>" <%= "disabled" if markdown.blank? %>>挿入</button>
                  <%= link_to "削除", admin_post_image_path(post, image), class: "outline-danger", data: { turbo_method: :delete, turbo_confirm: "この画像を削除します。本文にURLが残っている場合は画像切れになります。" } %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="empty-note">添付画像はありません。</p>
        <% end %>
      </section>
    <% end %>

    <div class="modal-backdrop" data-publish-modal-backdrop hidden>
      <div class="publish-modal-card" role="dialog" aria-labelledby="modal-title" aria-modal="true">
        <div class="modal-header">
          <h2 id="modal-title">公開設定</h2>
          <button type="button" class="close-button" data-close-publish-modal aria-label="閉じる">✕</button>
        </div>
        <div class="modal-body editor-fields">
          <label>
            <span>スラッグ <b>*</b></span>
            <%= form.text_field :slug, required: true, pattern: "[a-z0-9]+(-[a-z0-9]+)*", title: "半角英数字とハイフンで入力してください" %>
          </label>
          <label>
            <span>カテゴリー</span>
            <%= form.collection_select :category_id, categories, :id, :name %>
          </label>
          <label>
            <span>種別</span>
            <%= form.select :kind, options_for_select(Post.kinds.keys.map { |kind| [ kind_label(kind), kind ] }, post.kind) %>
          </label>
          <label class="span-full">
            <span>タグ（カンマ区切りで入力）</span>
            <%= form.text_field :tag_names, value: post.tag_names, placeholder: "Terraform, IaC, AWS", data: { tag_input: true } %>
            <span class="tag-preview chip-list" data-tag-preview>
              <% post.tag_names.split(",").map(&:strip).reject(&:blank?).each do |tag_name| %>
                <span class="chip"><%= tag_name %></span>
              <% end %>
            </span>
          </label>
          <label class="span-full">
            <span>記事の要約（エクサープト）</span>
            <div class="ai-summary-controls">
              <button type="button" class="secondary-button" data-action="post-summary#generate" data-post-summary-target="button">AIで要約生成</button>
              <small>現在のタイトルと本文を外部AIに送信し、生成結果を要約欄に反映します。</small>
            </div>
            <%= form.text_area :excerpt, rows: 3, maxlength: 100, data: { live_count_input: "excerpt", live_count_max: 100, post_summary_target: "excerpt" } %>
            <em data-live-count-output="excerpt"><%= post.excerpt.to_s.length %> / 100</em>
            <strong class="ai-summary-message" data-post-summary-target="message" hidden></strong>
          </label>
          <label>
            <span>ステータス</span>
            <%= form.select :status, options_for_select(Post.statuses.keys.map { |status| [ status_label(status), status ] }, post.status) %>
          </label>
          <label>
            <span>公開日時</span>
            <%= form.datetime_local_field :published_at %>
          </label>
        </div>
        <div class="modal-footer">
          <button type="button" class="secondary-button" data-close-publish-modal>キャンセル</button>
          <button type="button" class="secondary-button" disabled>公開予約（準備中）</button>
          <button type="submit" name="commit_status" value="draft" class="secondary-button" formnovalidate>下書き保存</button>
          <button type="submit" name="commit_status" value="published" class="primary-button">投稿を公開する</button>
        </div>
      </div>
    </div>
  <% end %>
</main>
