<main class="settings-page">
  <nav class="breadcrumbs">
    <%= link_to t("admin.settings.show.home"), root_path %>
    <span>›</span>
    <span><%= t("admin.settings.show.admin") %></span>
    <span>›</span>
    <span><%= t("admin.settings.show.title") %></span>
  </nav>

  <%= form_with model: @setting, url: admin_settings_path, method: :patch do |form| %>
    <% if @setting.errors.any? %>
      <div class="error-box"><%= @setting.errors.full_messages.join(" / ") %></div>
    <% end %>

    <div class="admin-title-row">
      <h1><%= t("admin.settings.show.h1") %></h1>
      <div class="title-actions">
        <%= link_to t("admin.settings.show.preview"), root_path, class: "secondary-button" %>
        <%= form.submit t("admin.settings.show.save"), class: "primary-button" %>
      </div>
    </div>

    <section class="settings-card">
      <div class="settings-card-title"><span>▤</span><h2><%= t("admin.settings.show.blog_section") %></h2><p><%= t("admin.settings.show.blog_section_desc") %></p></div>
      <div class="settings-fields">
        <label><span><%= t("admin.settings.show.blog_title") %></span><%= form.text_field :blog_title %></label>
        <label><span><%= t("admin.settings.show.tagline") %></span><%= form.text_field :tagline %></label>
        <label><span><%= t("admin.settings.show.site_url") %></span><%= form.url_field :site_url %></label>
        <label class="wide"><span><%= t("admin.settings.show.blog_description") %></span><%= form.text_area :description, rows: 3 %></label>
        <label class="upload-placeholder" data-settings-image-preview-container>
          <span>▧</span>
          <% if @setting.ogp_image.attached? && @setting.ogp_image.blob.persisted? %>
            <%= image_tag @setting.ogp_image, alt: "OGP画像", class: "settings-thumb", data: { settings_image_preview: true } %>
          <% else %>
            <p data-settings-image-placeholder><%= t("admin.settings.show.ogp_placeholder").html_safe %></p>
          <% end %>
          <%= form.file_field :ogp_image, accept: "image/png,image/jpeg", id: "site_setting_ogp_image", data: { settings_image_input: true, preview_alt: "OGP画像", preview_class: "settings-thumb" } %>
        </label>
        <label class="secondary-button file-label" for="site_setting_ogp_image"><%= t("admin.settings.show.change_image") %></label>
        <p class="settings-save-notice" data-settings-image-save-notice hidden><%= t("admin.settings.show.save_notice") %></p>
      </div>
    </section>

    <section class="settings-card">
      <div class="settings-card-title"><span>♙</span><h2><%= t("admin.settings.show.profile_section") %></h2><p><%= t("admin.settings.show.profile_section_desc") %></p></div>
      <div class="settings-fields">
        <label><span><%= t("admin.settings.show.display_name") %></span><%= form.text_field :profile_name %></label>

        <div class="translation-field-group" data-controller="profile-translator" data-profile-translator-url-value="<%= admin_profile_translation_path %>" data-profile-translator-field-value="title" data-profile-translator-translating-value="<%= t("admin.settings.show.translating") %>" data-profile-translator-success-value="<%= t("admin.settings.show.translate_success") %>" data-profile-translator-error-value="<%= t("admin.settings.show.translate_error") %>">
          <label>
            <span><%= t("admin.settings.show.title") %></span>
            <%= form.text_field :profile_title, data: { profile_translator_target: "source" } %>
          </label>
          <label>
            <span><%= t("admin.settings.show.title_en") %></span>
            <span class="translation-field-row">
              <%= form.text_field :profile_title_en, data: { profile_translator_target: "target" } %>
              <button type="button" class="secondary-button compact" data-action="profile-translator#translate" data-profile-translator-target="button">🧠</button>
            </span>
          </label>
          <span hidden data-profile-translator-target="message" class="translation-message"></span>
        </div>

        <label><span><%= t("admin.settings.show.email") %></span><%= form.email_field :profile_email %></label>

        <div class="translation-field-group" data-controller="profile-translator" data-profile-translator-url-value="<%= admin_profile_translation_path %>" data-profile-translator-field-value="bio" data-profile-translator-translating-value="<%= t("admin.settings.show.translating") %>" data-profile-translator-success-value="<%= t("admin.settings.show.translate_success") %>" data-profile-translator-error-value="<%= t("admin.settings.show.translate_error") %>">
          <label class="wide">
            <span><%= t("admin.settings.show.bio") %></span>
            <%= form.text_area :profile_bio, rows: 3, data: { profile_translator_target: "source" } %>
          </label>
          <label class="wide">
            <span><%= t("admin.settings.show.bio_en") %></span>
            <%= form.text_area :profile_bio_en, rows: 3, data: { profile_translator_target: "target" } %>
          </label>
          <div class="translation-actions">
            <button type="button" class="secondary-button" data-action="profile-translator#translate" data-profile-translator-target="button">🧠 <span><%= t("admin.settings.show.translate_bio") %></span></button>
            <span hidden data-profile-translator-target="message"></span>
          </div>
        </div>

        <label class="settings-avatar-upload" data-settings-image-preview-container>
          <% if @setting.profile_image.attached? && @setting.profile_image.blob.persisted? %>
            <%= image_tag @setting.profile_image, alt: "プロフィール画像", class: "settings-avatar-image", data: { settings_image_preview: true } %>
          <% else %>
            <span class="settings-avatar avatar-drawing" data-settings-image-placeholder><span class="face"></span></span>
          <% end %>
          <%= form.file_field :profile_image, accept: "image/png,image/jpeg", id: "site_setting_profile_image", data: { settings_image_input: true, preview_alt: "プロフィール画像", preview_class: "settings-avatar-image" } %>
        </label>
        <label class="secondary-button file-label" for="site_setting_profile_image"><%= t("admin.settings.show.change_avatar") %></label>
        <p class="settings-save-notice" data-settings-image-save-notice hidden><%= t("admin.settings.show.save_notice") %></p>
      </div>
    </section>

    <section class="settings-card">
      <div class="settings-card-title"><span>🔗</span><h2><%= t("admin.settings.show.sns_section") %></h2><p><%= t("admin.settings.show.sns_section_desc") %></p></div>
      <div class="settings-fields social-settings">
        <label><span><%= t("admin.settings.show.github") %></span><%= form.url_field :github_url %></label>
        <label><span><%= t("admin.settings.show.x") %></span><%= form.url_field :x_url %></label>
        <label><span><%= t("admin.settings.show.rss") %></span><%= form.url_field :rss_url %></label>
        <label><span><%= t("admin.settings.show.zenn") %></span><%= form.url_field :zenn_url %></label>
        <label><span><%= t("admin.settings.show.note") %></span><%= form.url_field :note_url %></label>
      </div>
    </section>

    <section class="settings-card compact">
      <div class="settings-card-title"><span>◉</span><h2><%= t("admin.settings.show.display_section") %></h2><p><%= t("admin.settings.show.display_section_desc") %></p></div>
      <div class="settings-fields">
        <label class="toggle-label"><%= form.check_box :profile_visible %><span><%= t("admin.settings.show.profile_visible") %></span></label>
        <label class="toggle-label"><%= form.check_box :sns_visible %><span><%= t("admin.settings.show.sns_visible") %></span></label>
        <label><span>デフォルトテーマ</span><%= form.select :default_theme, [ [ t("admin.settings.show.theme_light"), "light" ], [ t("admin.settings.show.theme_dark"), "dark" ] ] %></label>
        <label><span><%= t("admin.settings.show.posts_per_page") %></span><%= form.select :posts_per_page, [ 5, 10, 20, 50 ] %></label>
      </div>
    </section>

    <section class="settings-card compact">
      <div class="settings-card-title"><span>▣</span><h2><%= t("admin.settings.show.password_section") %></h2><p><%= t("admin.settings.show.password_section_desc") %></p></div>
      <div class="settings-fields">
        <label>
          <span><%= t("admin.settings.show.current_password") %></span>
          <span class="password-field"><%= password_field_tag :current_password, nil, placeholder: t("admin.settings.show.current_password_placeholder") %><%= button_tag type: "button", data: { password_toggle: true, password_toggle_label: t("admin.settings.show.current_password"), password_toggle_show: t("js.password_toggle.show"), password_toggle_hide: t("js.password_toggle.hide") }, aria: { label: t("js.password_toggle.show"), pressed: "false" } do %>◎<% end %></span>
        </label>
        <label>
          <span><%= t("admin.settings.show.new_password") %></span>
          <span class="password-field"><%= password_field_tag :new_password, nil, placeholder: t("admin.settings.show.new_password_placeholder") %><%= button_tag type: "button", data: { password_toggle: true, password_toggle_label: t("admin.settings.show.new_password"), password_toggle_show: t("js.password_toggle.show"), password_toggle_hide: t("js.password_toggle.hide") }, aria: { label: t("js.password_toggle.show"), pressed: "false" } do %>◎<% end %></span>
          <small><%= t("admin.settings.show.password_rule") %></small>
        </label>
        <label>
          <span><%= t("admin.settings.show.confirm_password") %></span>
          <span class="password-field"><%= password_field_tag :new_password_confirmation, nil, placeholder: t("admin.settings.show.confirm_password_placeholder") %><%= button_tag type: "button", data: { password_toggle: true, password_toggle_label: t("admin.settings.show.confirm_password"), password_toggle_show: t("js.password_toggle.show"), password_toggle_hide: t("js.password_toggle.hide") }, aria: { label: t("js.password_toggle.show"), pressed: "false" } do %>◎<% end %></span>
        </label>
        <button type="submit" class="outline-danger"><%= t("admin.settings.show.update_password") %></button>
      </div>
    </section>

    <p class="last-updated"><%= t("admin.settings.show.last_updated") %> <%= @setting.updated_at&.strftime("%Y-%m-%d %H:%M") || Time.current.strftime("%Y-%m-%d %H:%M") %></p>
  <% end %>
</main>
