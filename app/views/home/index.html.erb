<main class="page-grid top-page">
  <section class="content-area">
    <section class="hero-section">
      <div class="hero-copy">
        <h1><%= t("home.index.hero").html_safe %></h1>
        <p><%= t("home.index.hero_sub") %></p>
        <ul class="check-list">
          <li><%= t("home.index.feature_1") %></li>
          <li><%= t("home.index.feature_2") %></li>
          <li><%= t("home.index.feature_3") %></li>
        </ul>
      </div>

      <article class="daily-card">
        <div class="paperclip" aria-hidden="true"></div>
        <p class="section-kicker"><%= t("home.index.daily_log") %></p>
        <% if @daily_log.present? %>
          <time><%= @daily_log.display_date.strftime("%Y-%m-%d") %></time>
          <h2><%= @daily_log.title %></h2>
        <% else %>
          <time><%= Date.current.strftime("%Y-%m-%d") %></time>
          <h2>TerraformでS3バケットを作ってみる</h2>
        <% end %>
        <% daily_code = [
          'resource "aws_s3_bucket" "example" {',
          '  bucket = "hiroe-tech-notes"',
          '  acl    = "private"',
          "  tags = {",
          '    Name = "hiroe-tech-notes-bucket"',
          "  }",
          "}"
        ].join("\n") %>
        <pre class="code-card highlight language-terraform"><code class="highlight"><%= highlight_code(daily_code, language: "terraform") %></code></pre>
        <p class="memo"><%= t("home.index.memo").html_safe %></p>
        <%= link_to t("home.index.continue_to_experiments"), experiments_path, class: "daily-link" %>
      </article>
    </section>

    <section class="note-section latest-posts">
      <div class="section-heading">
        <h2><%= t("home.index.latest_posts") %></h2>
        <div class="filter-tabs">
          <%= link_to t("home.index.all"), posts_path, class: "active" %>
          <% %w[infrastructure aws automation programming security ai-development].each do |slug| %>
            <% if (category = @top_filter_categories[slug]) %>
              <%= link_to category.name, posts_path(category: category.slug) %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="article-lines">
        <% @latest_posts.each do |post| %>
          <%= link_to post_path(post), class: "article-line" do %>
            <time><%= post.display_date.strftime("%Y-%m-%d") %></time>
            <strong><%= post.title %></strong>
            <span class="line-tags">
              <% post.tags.limit(2).each do |tag| %>
                <span class="chip"><%= tag.name %></span>
              <% end %>
            </span>
          <% end %>
        <% end %>
      </div>
      <%= link_to t("home.index.view_all_articles"), posts_path, class: "text-link align-right" %>
    </section>

    <section class="note-section experiments-section">
      <div class="section-heading">
        <h2><%= t("home.index.experiments") %> <span><%= t("home.index.experiments_sub") %></span></h2>
      </div>
      <div class="experiment-cards">
        <% @experiments.each do |post| %>
          <%= link_to post_path(post), class: "experiment-card" do %>
            <time><%= post.display_date.strftime("%Y-%m-%d") %></time>
            <h3><%= post.title %></h3>
            <% if (preview = post.body_preview) %>
              <div class="experiment-card-preview">
                <% if preview[:type] == :image %>
                  <img src="<%= preview[:url] %>" alt="<%= preview[:alt] %>" loading="lazy" class="experiment-card-image">
                <% elsif preview[:type] == :code %>
                  <pre class="experiment-card-code"><code><%= highlight_code(preview[:code], language: preview[:language] || "text") %></code></pre>
                <% end %>
              </div>
            <% end %>
            <p><%= post.excerpt %></p>
            <footer>
              <span>#<%= post.tags.first&.name || post.category.name %></span>
              <span>◷ <%= post.reading_minutes * 15 %><%= t("home.index.minutes") %></span>
            </footer>
          <% end %>
        <% end %>
      </div>
      <%= link_to t("home.index.view_all_experiments"), experiments_path, class: "text-link align-right" %>
    </section>
  </section>

  <%= render "shared/sidebar", categories: @categories, archives: @archives %>
</main>
