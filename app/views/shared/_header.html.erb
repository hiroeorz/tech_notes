<header class="site-header <%= "login-header" if controller_path == "admin/sessions" %>">
  <div class="brand">
    <%= link_to root_path, class: "brand-link" do %>
      <span class="brand-title"><%= current_site_setting.blog_title %></span>
      <span class="brand-tagline"><%= current_site_setting.tagline %></span>
    <% end %>
  </div>

  <% unless controller_path == "admin/sessions" %>
    <nav class="global-nav" aria-label="<%= t("shared.header.nav_aria") %>" data-menu-nav>
      <%= link_to t("shared.header.home"), root_path, class: ("active" if current_page?(root_path)) %>
      <%= link_to t("shared.header.articles"), posts_path, class: ("active" if controller_name == "posts" && action_name != "tags" && params[:kind] != "experiment" && request.path != experiments_path) %>
      <%= link_to t("shared.header.experiments"), experiments_path, class: ("active" if request.path == experiments_path || params[:kind] == "experiment") %>
      <%= link_to t("shared.header.tags"), tags_path, class: ("active" if current_page?(tags_path)) %>
      <% if current_site_setting.profile_visible? %>
        <%= link_to t("shared.header.profile"), profile_path, class: ("active" if current_page?(profile_path)) %>
      <% end %>
      <%= link_to t("shared.header.about"), about_path, class: ("active" if current_page?(about_path)) %>
    </nav>
  <% end %>

  <div class="header-actions">
    <% if admin_signed_in? && controller_path.start_with?("admin/") && controller_path != "admin/sessions" %>
      <%= link_to t("shared.header.admin_posts"), admin_posts_path, class: "admin-link" %>
      <%= link_to t("shared.header.admin_settings"), admin_settings_path, class: "admin-link" %>
      <%= button_to t("shared.header.logout"), admin_logout_path, method: :delete, class: "logout-link" %>
    <% end %>
    <div class="locale-switch">
      <label class="locale-label" aria-label="<%= t("shared.header.language_select") %>">
        <select data-controller="locale" data-action="locale#change" class="locale-select">
          <option value="en" <%= "selected" if I18n.locale == :en %>><%= t("shared.header.language_en") %></option>
          <option value="ja" <%= "selected" if I18n.locale == :ja %>><%= t("shared.header.language_ja") %></option>
        </select>
      </label>
    </div>
    <button class="menu-toggle" type="button" data-menu-toggle aria-label="<%= t("shared.header.menu") %>" aria-expanded="false">☰</button>
    <button class="icon-button" type="button" data-theme-toggle aria-label="<%= t("shared.header.theme_toggle") %>" aria-pressed="<%= current_site_setting.default_theme == "dark" %>">☾</button>
    <button class="icon-button" type="button" data-search-toggle aria-label="<%= t("shared.header.search") %>">⌕</button>
  </div>
</header>

<div class="search-panel" data-search-panel hidden>
  <%= form_with url: posts_path, method: :get, class: "search-panel-form" do |form| %>
    <%= form.search_field :q, placeholder: t("shared.header.search_placeholder"), aria: { label: t("shared.header.search_placeholder") } %>
    <%= form.submit t("shared.header.search_button"), class: "primary-button" %>
  <% end %>
</div>
